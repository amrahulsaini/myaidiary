# MyAIDiary — environment template (safe to commit; NO real values).
# Copy to .env.local and fill in. Real secrets live in SECRETS.local.md (gitignored).

# PostgreSQL (Coolify pgvector). Local dev: use the DB's public port or a local postgres.
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/myaidiary"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Public site URL
NEXT_PUBLIC_SITE_URL="https://myaidiary.me"

# Google Gemini (AI features)
GEMINI_API_KEY=""

# Google OAuth (sign-in) — from Google Cloud Console
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
