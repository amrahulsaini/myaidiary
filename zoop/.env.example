# ===== Zoop config =====

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Gemini model used to generate replies + summaries
GEMINI_MODEL=gemini-2.5-flash

# Dashboard
PORT=3001
HOST=0.0.0.0
DASHBOARD_PASSWORD=change-me-now
SESSION_SECRET=change-this-to-a-long-random-string
# IMPORTANT: Keep MASTER_KEY stable forever — changing it makes all encrypted data unreadable
MASTER_KEY=change-this-to-another-long-random-string

# Reply behaviour
# REPLY_MODE: auto | approval | off
REPLY_MODE=auto
# Only reply to 1:1 DMs (true) or also groups when mentioned (false)
DM_ONLY=true

# Throttling (anti-ban). Delays are in milliseconds.
# These are "instant" defaults. To play safer, raise them (e.g. 4000/12000/6000/8/15000).
MIN_REPLY_DELAY_MS=400
MAX_REPLY_DELAY_MS=1500
# Wait this long after the last incoming msg before replying (collect message bursts,
# so a flurry of texts gets ONE reply instead of looking like a bot). Keep >= ~1000.
BURST_DEBOUNCE_MS=1200
# Hard caps
MAX_REPLIES_PER_MINUTE=30
MIN_GAP_PER_CONTACT_MS=1500

# Summarize a conversation after this many new messages
SUMMARIZE_EVERY_N_MESSAGES=10
